generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  USER
  RESCUER
  VET
  ADMIN
}

enum ReportStatus {
  REPORTED
  ASSIGNED
  RESCUED
  TREATED
  ADOPTED
}

enum AdoptionStatus {
  PENDING
  INTERVIEW_SCHEDULED
  APPROVED
  REJECTED
}

enum CampaignStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DonationType {
  FOOD
  TREATMENT
  SHELTER
  CAMPAIGN
}

enum SubscriptionType {
  FOOD
  TREATMENT
  SHELTER
}

//////////////////////
// USER
//////////////////////

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String
  role         Role    @default(USER)
  avatarUrl    String?
  isVerified   Boolean @default(false)
  refreshToken String?

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id])

  reports  AnimalReport[]
  posts    FeedPost[]
  comments Comment[]

  donations     Donation[]
  subscriptions Subscription[]
  volunteers    Volunteer[]

  adoptionRequests AdoptionRequest[]
  ownedPets        Pet[]             @relation("PetOwner")

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  medicalRecords MedicalRecord[]
  campaigns      Campaign[]
}

//////////////////////
// CLINIC
//////////////////////

model Clinic {
  id         String  @id @default(uuid())
  name       String
  address    String?
  city       String?
  contact    String?
  isVerified Boolean @default(false)

  users          User[]
  reports        AnimalReport[]
  pets           Pet[]
  campaigns      Campaign[]
  medicalRecords MedicalRecord[]
  subscriptions  Subscription[]

  createdAt DateTime   @default(now())
  donations Donation[]
}

//////////////////////
// STRAY REPORT
//////////////////////

model AnimalReport {
  id String @id @default(uuid())

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id])

  status ReportStatus @default(REPORTED)

  locationLat Float
  locationLng Float
  description String
  mediaUrls   String[]

  assignedRescuerId String?
  assignedVetId     String?
  assignedClinicId  String?

  clinic Clinic? @relation(fields: [assignedClinicId], references: [id])

  medicalRecords MedicalRecord[]
  pet            Pet?

  campaigns Campaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// MEDICAL RECORD
//////////////////////

model MedicalRecord {
  id String @id @default(uuid())

  reportId String
  report   AnimalReport @relation(fields: [reportId], references: [id])

  vetId String
  vet   User   @relation(fields: [vetId], references: [id])

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  diagnosis String?
  treatment String?

  createdAt DateTime @default(now())
}

//////////////////////
// PET (ADOPTION READY)
//////////////////////

model Pet {
  id String @id @default(uuid())

  reportId String?       @unique
  report   AnimalReport? @relation(fields: [reportId], references: [id])

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id])

  ownerId String
  owner   User   @relation("PetOwner", fields: [ownerId], references: [id])

  name        String?
  breed       String?
  age         Int?
  gender      String?
  size        String?
  description String?

  status String @default("AVAILABLE")

  adoptionRequests AdoptionRequest[]

  createdAt DateTime @default(now())
}

//////////////////////
// ADOPTION REQUEST
//////////////////////

model AdoptionRequest {
  id String @id @default(uuid())

  petId String
  pet   Pet    @relation(fields: [petId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status      AdoptionStatus @default(PENDING)
  formDetails Json

  interviewDate     DateTime?
  interviewTime     String?
  interviewLocation String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// CAMPAIGNS
//////////////////////

model Campaign {
  id String @id @default(uuid())

  title        String
  description  String
  goalAmount   Float
  raisedAmount Float  @default(0)

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  reportId String?
  report   AnimalReport? @relation(fields: [reportId], references: [id])

  createdBy String
  creator   User   @relation(fields: [createdBy], references: [id])

  status CampaignStatus @default(PENDING)

  donations  Donation[]
  volunteers Volunteer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// DONATIONS
//////////////////////

model Donation {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  amount Float
  type   DonationType

  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id])

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  paymentIntentId String @unique
  status          String @default("PENDING")

  createdAt DateTime @default(now())
}

//////////////////////
// SUBSCRIPTIONS
//////////////////////

model Subscription {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  clinicId String
  clinic   Clinic @relation(fields: [clinicId], references: [id])

  type SubscriptionType

  stripeSubscriptionId String @unique
  amount               Float

  status       String   @default("ACTIVE")
  nextCheckout DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// VOLUNTEERS (NEW)
//////////////////////

model Volunteer {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id])

  status String @default("APPLIED")

  createdAt DateTime @default(now())

  @@unique([userId, campaignId])
}

//////////////////////
// COMMUNITY
//////////////////////

model FeedPost {
  id String @id @default(uuid())

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  content   String
  mediaUrls String[]

  likesCount Int @default(0)

  comments Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id String @id @default(uuid())

  postId String
  post   FeedPost @relation(fields: [postId], references: [id])

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  content String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
